# Dependency directories
node_modules/

# Python virtual environment
.venv/
venv/
*.egg-info/

# Package lock files
package-lock.json

# Environment files & secrets — NEVER COMMIT
.env
.env.*
.creds/
creds/
*.key
*.pem
*.json.key
service-account*.json

# Runtime output (generated at runtime, not tracked)
output/
logs/

# OS generated files
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo

# Puppeteer / Playwright / DrissionPage caches
.cache/
tmp_userdata*/

# Python caches
__pycache__/
*.pyc
*.pyo

# Test and coverage artifacts
.coverage
coverage/
.pytest_cache/
htmlcov/

# Build artifacts
build/
dist/
.dist/
.tmp/

# Scraper debug artifacts
*results_debug.html
*results_debug.png
*.jsonl

# Stale git directories (cleanup remnants)
.git 2/
.git 3/

# Old directories — superseded by counties/ and core/
# (Safe to remove after running scripts/cleanup_old_dirs.sh)
apps_script/
wix_integration/
normalizers/
shared/
writers/
fixtures/

# Old python virtualenvs
python_scrapers/venv*/
python_scrapers/.patchright-browsers/
python_scrapers/.playwright-browsers/

# Debug artifacts
debug_*.html
debug_*.png
browser_server.py
